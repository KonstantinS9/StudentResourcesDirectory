@using StudentResourcesDirectory.ViewModels.AdminViewModels.ResourceManagementViewModels
@model IEnumerable<ResourceManagementViewModel>

@{
    ViewData["Title"] = "Resources";
}

<div class="container mt-5">
    <h1 class="text-center mb-4 text-warning fw-bold">Resource Management</h1>

    <div class="d-flex justify-content-between mb-3">
        <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="btn btn-secondary fw-bold">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>

        <a asp-action="Create" class="btn btn-success fw-bold">
            <i class="bi bi-plus-circle"></i> Add Resource
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-dark table-hover shadow-lg rounded-3">
            <thead>
                <tr class="text-warning text-center">
                    <th>Title</th>
                    <th>Description</th>
                    <th>Type</th>
                    <th>Created On</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var resource in Model)
                    {
                        <tr>
                            <td class="align-middle">@resource.Title</td>

                            <td class="align-middle">
                                @(resource.Description.Length > 50
                                    ? resource.Description.Substring(0, 50) + "..."
                                    : resource.Description)
                            </td>

                            <td class="align-middle text-center">
                                <span class="badge bg-info text-dark fw-bold px-3 py-2 rounded-pill">
                                    @resource.ResourceType
                                </span>
                            </td>

                            <td class="align-middle text-center">
                                @resource.CreatedOn.ToString("dd MMM yyyy")
                            </td>

                            <td class="text-center align-middle">
                                <div class="d-flex justify-content-center gap-2">
                                    
                                    <a href="@resource.Url" target="_blank"
                                           class="btn btn-sm btn-info fw-bold">
                                        <i class="bi bi-box-arrow-up-right"></i>
                                    </a>

                                    <a asp-action="Edit" asp-route-id="@resource.Id"
                                           class="btn btn-sm btn-primary fw-bold">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <a asp-action="Delete" asp-route-id="@resource.Id"
                                           class="btn btn-sm btn-danger fw-bold">
                                        <i class="bi bi-trash"></i>
                                    </a>

                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-light">
                            No resources found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    body {
        background-color: #1c1c1c;
    }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
