@using StudentResourcesDirectory.ViewModels.AdminViewModels.StudentManagementViewModels
@model StudentManagementViewModel

@{
    ViewData["Title"] = "Delete Student";
}

<div class="container mt-5">
    <div class="text-center">
        <h2 class="text-danger fw-bold mb-4">
            <i class="bi bi-exclamation-triangle-fill"></i> Delete Student
        </h2>
        <p class="text-light">Are you sure you want to delete this student?</p>
    </div>

    <div class="card bg-dark text-white shadow-lg rounded-3 mx-auto mt-4" style="max-width: 500px;">
        <div class="card-body text-center">
            <h5 class="fw-bold">@Model.Email</h5>

            <div class="mt-4 d-flex justify-content-center gap-3">
                <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger fw-bold px-4">
                        <i class="bi bi-trash-fill"></i> Delete
                    </button>
                </form>

                <a asp-action="Index" class="btn btn-secondary fw-bold px-4">
                    <i class="bi bi-x-circle"></i> Cancel
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #1c1c1c;
    }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">