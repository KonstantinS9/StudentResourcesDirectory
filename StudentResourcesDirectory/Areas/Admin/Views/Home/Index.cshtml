@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-5">
    <div class="text-center">
        <h1 class="display-4 mb-3 text-warning fw-bold">Welcome to the Admin Dashboard</h1>
        <p class="lead mb-5 text-light">Manage your system using the sections below:</p>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 bg-dark text-white rounded-3 h-100 dashboard-card">
                <div class="card-body d-flex flex-column align-items-center text-center">
                    <i class="bi bi-people-fill text-warning display-3 mb-3"></i>
                    <h5 class="card-title fw-bold">Manage Students</h5>
                    <p class="card-text text-light">Add, edit, or remove students easily.</p>
                    <div class="mt-auto w-100">
                        <a asp-area="Admin" asp-controller="StudentManagement" asp-action="Index"
                               class="btn btn-warning fw-bold shadow-sm w-100 py-2">
                            <i class="bi bi-person-badge-fill"></i> Go to Students
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-lg border-0 bg-dark text-white rounded-3 h-100 dashboard-card">
                <div class="card-body d-flex flex-column align-items-center text-center">
                    <i class="bi bi-book-fill text-primary display-3 mb-3"></i>
                    <h5 class="card-title fw-bold">Manage Resources</h5>
                    <p class="card-text text-light">Upload, edit, and organize resources.</p>
                    <div class="mt-auto w-100">
                        <a asp-controller="ResourceManagement" asp-action="Index"
                               class="btn btn-primary fw-bold shadow-sm w-100 py-2">
                            <i class="bi bi-folder-fill"></i> Go to Resources
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: white;
    }

    .dashboard-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .dashboard-card:hover {
            transform: translateY(-5px) scale(1.02);
            box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.4);
        }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">