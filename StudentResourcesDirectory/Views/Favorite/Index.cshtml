@using StudentResourcesDirectory.ViewModels.ResourceViewModels
@model IEnumerable<ResourceViewModel>

@{
    ViewData["Title"] = "My Favorite Resources";
}

<div class="container mt-5">

    <div class="text-center mb-5">
        <h1 class="fw-bold">❤️ My Favorite Resources</h1>
        <p class="text-muted">All resources you have saved</p>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            You have no favorite resources yet.
        </div>
    }
    else
    {
        <div class="row g-4">

            @foreach (var resource in Model)
            {
                <div class="col-md-6 col-lg-4">

                    <div class="card h-100 shadow-sm border-0">

                        <div class="card-body d-flex flex-column">

                            <div class="mb-2">
                                <span class="badge bg-primary">
                                    @resource.ResourceType
                                </span>
                            </div>

                            <h5 class="fw-bold mb-2">
                                @resource.Title
                            </h5>

                            <p class="small text-secondary mb-1">
                                📂 @resource.Description
                            </p>

                            <p class="small text-secondary mb-1">
                                📁 @resource.Category
                            </p>

                            <p class="small text-secondary mb-3">
                                👤 @resource.Student
                            </p>

                            <div class="mt-auto">

                                <a asp-controller="Resource"
                                       asp-action="Details"
                                       asp-route-id="@resource.Id"
                                       class="btn btn-outline-primary w-100 mb-2">
                                    View Details
                                </a>

                                <a href="@resource.Url"
                                       target="_blank"
                                       class="btn btn-outline-success w-100 mb-2">
                                    Open Resource
                                </a>

                                <form asp-controller="Favorite"
                                      asp-action="Remove"
                                      asp-route-id="@resource.Id"
                                      method="post">

                                    <button class="btn btn-danger w-100">
                                        ❌ Remove
                                    </button>

                                </form>

                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>
    }

    <div class="text-center mt-5">
        <a asp-controller="Resource"
               asp-action="Index"
               class="btn btn-outline-secondary">
            ⬅ Back to Resources
        </a>
    </div>

</div>