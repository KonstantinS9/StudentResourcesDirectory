@using StudentResourcesDirectory.ViewModels.ResourceViewModels
@model IEnumerable<ResourceViewModel>

@{
    ViewData["Title"] = "Resources";
    var currentUserId = ViewData["CurrentUserId"] as string;
}

<form method="get" asp-action="Index" class="mb-4">
    <div class="row">
        <div class="col">
            <input type="text"
                   name="searchQuery"
                   class="form-control"
                   placeholder="Search by title..."
                   value="@ViewData["SearchQuery"]" />
        </div>
        <div class="col">
            <input type="text"
                   name="resourceType"
                   class="form-control"
                   placeholder="Filter by resource type..."
                   value="@ViewData["ResourceType"]" />
        </div>
        <div class="col">
            <input type="text"
                   name="category"
                   class="form-control"
                   placeholder="Filter by category..."
                   value="@ViewData["Category"]" />
        </div>
        <div class="col">
            <button type="submit" class="btn btn-primary">Filter</button>
        </div>
    </div>
</form>

<div class="container mt-4">

    <div class="text-center mb-5">
        <h1 class="fw-bold">📚 Learning Resources</h1>
        <p class="text-muted">Browse and manage shared student materials</p>

            <a asp-action="Create" class="btn btn-success">
                + Add New Resource
            </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            No resources found.
        </div>
    }
    else
    {
        <div class="row g-4">

            @foreach (var resource in Model)
            {
                <div class="col-md-6 col-lg-4">

                    <div class="card resource-card h-100 shadow-sm border-0">

                        <div class="card-body d-flex flex-column">

                            <div class="mb-2">
                                <span class="badge bg-dark">
                                    @resource.ResourceType
                                </span>
                            </div>

                            <h5 class="fw-bold mb-2">@resource.Title</h5>

                            <p class="small text-secondary mb-1">
                                📂 @resource.Description
                            </p>

                            <p class="small text-secondary mb-1">
                                📂 @resource.Category
                            </p>

                            <p class="small text-secondary mb-3">
                                👤 @(string.IsNullOrWhiteSpace(resource.Student) ? "Unknown" : resource.Student)
                            </p>

                            <form asp-controller="Favorite" asp-action="Add" method="post" class="mb-2">
                                <input type="hidden" name="resourceId" value="@resource.Id" />
                                <button type="submit" class="btn btn-outline-primary w-100">❤️ Add to Favorite</button>
                            </form>

                            <a asp-controller="Comment"
                                   asp-action="Add"
                                   asp-route-resourceId="@resource.Id"
                                   class="btn btn-outline-primary w-100 mb-2">
                                💬 Add Comment
                            </a>

                            <a asp-controller="Comment"
                                   asp-action="Index"
                                   asp-route-id="@resource.Id"
                                   class="btn btn-outline-primary w-100 mb-2">
                                📄 View Comments
                            </a>

                            <a asp-controller="Rating"
                                   asp-action="Add"
                                   asp-route-id="@resource.Id"
                                   class="btn btn-outline-primary w-100 mb-2">
                                ⭐ Add Rating
                            </a>

                            <a asp-controller="Rating"
                                   asp-action="Index"
                                   asp-route-id="@resource.Id"
                                   class="btn btn-outline-primary w-100 mb-2">
                                📊 View Ratings
                            </a>

                            <a href="@resource.Url"
                                   target="_blank"
                                   class="btn btn-outline-primary w-100 mb-2">
                                🔗 Open Resource
                            </a>

                            <div class="d-flex gap-1 mt-auto">
                                <a asp-action="Details"
                                       asp-route-id="@resource.Id"
                                       class="btn btn-info w-100 btn-sm">
                                    Details
                                </a>

                                @if (resource.StudentId.ToString() == currentUserId)
                                {
                                    <a asp-action="Edit"
                                           asp-route-id="@resource.Id"
                                           class="btn btn-warning w-100 btn-sm">
                                        Edit
                                    </a>

                                    <a asp-action="Delete"
                                           asp-route-id="@resource.Id"
                                           class="btn btn-danger w-100 btn-sm">
                                        Delete
                                    </a>
                                }
                            </div>

                        </div>
                    </div>
                </div>
            }

        </div>
    }

    <nav aria-label="Page navigation" class="mt-4">
        <ul class="pagination">
            @if ((int)ViewData["CurrentPage"] > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index"
                           asp-route-pageNumber="@( (int)ViewData["CurrentPage"] - 1 )"
                           asp-route-searchQuery="@ViewData["SearchQuery"]"
                           asp-route-genre="@ViewData["Genre"]"
                           asp-route-releaseYear="@ViewData["ReleaseYear"]">
                        Previous
                    </a>
                </li>
            }

            @for (int i = 1; i <= (int)ViewData["TotalPages"]; i++)
            {
                <li class="page-item @(i == (int)ViewData["CurrentPage"] ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                           asp-route-pageNumber="@i"
                           asp-route-searchQuery="@ViewData["SearchQuery"]"
                           asp-route-genre="@ViewData["Genre"]"
                           asp-route-releaseYear="@ViewData["ReleaseYear"]">
                        @i
                    </a>
                </li>
            }

            @if ((int)ViewData["CurrentPage"] < (int)ViewData["TotalPages"])
            {
                <li class="page-item">
                    <a class="page-link" asp-action="Index"
                           asp-route-pageNumber="@( (int)ViewData["CurrentPage"] + 1 )"
                           asp-route-searchQuery="@ViewData["SearchQuery"]"
                           asp-route-genre="@ViewData["Genre"]"
                           asp-route-releaseYear="@ViewData["ReleaseYear"]">
                        Next
                    </a>
                </li>
            }
        </ul>
    </nav>
</div>