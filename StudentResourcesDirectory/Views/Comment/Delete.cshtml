@using StudentResourcesDirectory.ViewModels.CommentViewModels
@model CommentDeleteViewModel

@{
    ViewData["Title"] = "Delete Comment";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow border-0">

                <div class="card-header bg-danger text-white text-center">
                    <h4>Delete Comment</h4>
                </div>

                <div class="card-body">

                    <p class="text-center text-muted mb-4">
                        Are you sure you want to delete this comment?
                    </p>

                    <div class="mb-3">
                        <strong>User:</strong> @Model.UserName
                    </div>

                    <div class="mb-3">
                        <strong>Date:</strong> @Model.CreatedOn.ToString("dd MMM yyyy HH:mm")
                    </div>

                    <div class="mb-4">
                        <strong>Comment:</strong>
                        <div class="border rounded p-3 bg-light mt-1">
                            @Model.Content
                        </div>
                    </div>

                    <form asp-action="DeleteConfirmed" method="post">

                        <input type="hidden" asp-for="Id" />

                        <div class="d-flex justify-content-between">

                            <a asp-action="Index"
                                   class="btn btn-secondary">
                                Cancel
                            </a>

                            <button type="submit"
                                    class="btn btn-danger">
                                Delete
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>